{
  "version": 1,
  "indentation": {
    "spaces": 4
  },
  "lineLength": 120,
  "maximumBlankLines": 1,
  "rules": {
    "NoBlockComments": false,
    "OrderedImports": true,
    "NoAssignmentInExpressions": true,
    "UseShorthandTypeNames": true,
    "UseExplicitNilCheckInConditions": true,
    "TypeNamesShouldBeCapitalized": true
  }
}
